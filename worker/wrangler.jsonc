{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "demo-agent-worker",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-21",
  "compatibility_flags": ["nodejs_compat"],

  "vars": {
    "LLM_BASE_URL": "https://api.deepseek.com",
    "LLM_MODEL": "deepseek-chat"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "demo-agent-db",
      "database_id": "a84e3f66-130f-4d79-90fc-e38d4974ac32"
    }
  ],

  "r2_buckets": [
    {
      "binding": "VIDEOS",
      "bucket_name": "demo-agent-videos"
    }
  ]
}
